{
  "name": "@mikebild/mikebild.com",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "develop": "svelte-kit dev",
    "build": "npm run clear && svelte-kit build",
    "preview": "svelte-kit preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check --plugin-search-dir=. . && eslint --ignore-path .gitignore .",
    "format": "prettier --write --plugin-search-dir=. .",
    "clear": "rimraf build .svelte-kit cdk.out",
    "lint:fix": "eslint --fix ./src/**/*.{ts,svelte}",
    "deploy": "cdk deploy --all --require-approval never --app cdk-cdn-construct",
    "deploy:local": "export $(cat .env | xargs) && npm run deploy",
    "destroy": "export $(cat .env | xargs) && cdk destroy --all --app cdk-cdn-construct"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "next",
    "@sveltejs/kit": "next",
    "@tailwindcss/jit": "0.1.18",
    "@typescript-eslint/eslint-plugin": "4.29.1",
    "@typescript-eslint/parser": "4.29.1",
    "autoprefixer": "10.3.1",
    "cssnano": "5.0.7",
    "eslint": "7.32.0",
    "eslint-plugin-svelte3": "3.2.0",
    "lint-staged": "11.1.2",
    "mdsvex": "0.9.8",
    "postcss": "8.3.6",
    "postcss-import": "14.0.2",
    "postcss-load-config": "3.1.0",
    "postcss-preset-env": "6.7.0",
    "prettier": "2.3.2",
    "prettier-plugin-svelte": "2.3.1",
    "rehype-autolink-headings": "6.0.0",
    "rehype-slug": "5.0.0",
    "remark-abbr": "1.4.1",
    "remark-github": "11.0.0",
    "svelte": "3.42.1",
    "svelte-preprocess": "4.7.4",
    "tailwindcss": "2.2.7",
    "tslib": "2.3.1",
    "typescript": "4.3.5",
    "vite": "2.5.0",
    "aws-cdk": "1.118.0",
    "cdk-cdn-construct": "1.1.3"
  },
  "type": "module"
}
